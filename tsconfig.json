{
	"extends": "@tsconfig/node22/tsconfig.json",
	"compilerOptions": {
		"customConditions": ["node"],
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"noImplicitOverride": true,
		"noUncheckedIndexedAccess": true,
		"strict": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["node_modules"]
}
